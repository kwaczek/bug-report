# Relay server configuration
PORT=3001
RELAY_SECRET=                   # Must match RELAY_SECRET on Railway backend (generate: openssl rand -hex 32)
RALPH_WORKSPACE=/Users/miro/Workspace/PERSONAL/ralph-workspace
GITHUB_TOKEN=                   # GitHub PAT for issue relabeling on fix failure
FIX_TIMEOUT_MS=3600000          # Max time for Ralph to complete a fix (default: 60 min)

# Cloudflare Tunnel Setup (one-time):
#   1. cloudflared tunnel login
#   2. cloudflared tunnel create bug-report-relay
#   3. cloudflared tunnel route dns bug-report-relay relay.yourdomain.com
#
# Running the tunnel (alongside relay server):
#   cloudflared tunnel run --url http://localhost:3001 bug-report-relay
#
# Or use a config file at ~/.cloudflared/config.yml:
#   tunnel: bug-report-relay
#   credentials-file: ~/.cloudflared/<tunnel-id>.json
#   ingress:
#     - hostname: relay.yourdomain.com
#       service: http://localhost:3001
#     - service: http_status:404
